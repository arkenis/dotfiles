{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Skill(ray-skill:*)",
      "Skill(euranka-guidelines:euranka-laravel-php:*)",
      "Skill(fix-github-issue:*)",
      "Skill(context7-auto-research:*)",
      "Skill(readability:*)",
      "Skill(agent-browser:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(composer:*)",
      "Bash(vendor/bin/phpunit:*)",
      "Bash(vendor/bin/pest:*)",
      "Bash(git:*)",
      "Bash(php artisan:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(php:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(make:*)",
      "Bash(brew:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(date:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(awk:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(open:*)",
      "WebSearch",
      "WebFetch",
      "mcp__laravel-boost__*",
      "mcp__chrome-devtools__*"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "agent-browser@agent-browser": true,
    "superpowers@claude-plugins-official": true,
    "marketing-skills@marketingskills": true,
    "cloudflare@cloudflare": true,
    "frontend-design@claude-plugins-official": true,
    "euranka-guidelines@euranka": true
  },
  "extraKnownMarketplaces": {
    "marketingskills": {
      "source": {
        "source": "github",
        "repo": "coreyhaines31/marketingskills"
      }
    },
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    },
    "typefully-skills": {
      "source": {
        "source": "github",
        "repo": "typefully/agent-skills"
      }
    },
    "euranka": {
      "source": {
        "source": "github",
        "repo": "euranka/tool.guidelines"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
